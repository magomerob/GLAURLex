# Copia este fichero a `.env` antes de `docker compose up -d`.

# --- Dominios y TLS -------------------------------------------------------
APP_HOST=glaurlex.example.com
AUTH_HOST=auth.example.com
# Dominio padre compartido por APP_HOST y AUTH_HOST para la cookie de sesión.
COOKIE_DOMAIN=example.com
# Email para Let's Encrypt (registración ACME).
ACME_EMAIL=admin@example.com

# --- Usuario del contenedor ----------------------------------------------
# UID/GID con el que correrá el proceso de la app. Debe coincidir con el
# propietario de HOST_DATA_DIR en el host. NUNCA pongas 0 (root).
PUID=1000
PGID=1000

# --- Persistencia ---------------------------------------------------------
# Directorio en el HOST donde vivirán los datos por-usuario. Cada usuario
# autenticado obtendrá su subcarpeta `<HOST_DATA_DIR>/<username>/processed`.
HOST_DATA_DIR=./var/data

# --- Zona horaria ---------------------------------------------------------
TZ=Europe/Madrid
