# Copia este fichero a `.env` antes de `docker compose up -d`.

# --- Imágenes -------------------------------------------------------------
# Versiones de cada servicio. Fija tags concretos (no `latest`) en producción.
TRAEFIK_IMAGE=traefik:v3.7.1
AUTHELIA_IMAGE=authelia/authelia:4.39.20
GLAURLEX_IMAGE=glaurlex:latest

# --- Dominios y TLS -------------------------------------------------------
APP_HOST=glaurlex.example.com
AUTH_HOST=auth.example.com
# Host del dashboard de Traefik (protegido por Authelia, grupo `admins`).
DASHBOARD_HOST=traefik.example.com
# Dominio padre compartido por APP_HOST y AUTH_HOST para la cookie de sesión.
COOKIE_DOMAIN=example.com
# Email para Let's Encrypt (registración ACME).
ACME_EMAIL=admin@example.com

# --- Puertos --------------------------------------------------------------
# Puertos publicados en el HOST por Traefik.
HTTP_PORT=80
HTTPS_PORT=443
# Puertos internos de cada backend (Traefik los enruta por la red `proxy`).
APP_PORT=8501
AUTH_PORT=9091

# --- Usuario del contenedor ----------------------------------------------
# UID/GID con el que correrá el proceso de la app. Debe coincidir con el
# propietario de HOST_DATA_DIR en el host. NUNCA pongas 0 (root).
PUID=1000
PGID=1000

# --- Persistencia (carpetas en el host) ---------------------
# Directorio en el HOST donde vivirán los datos por-usuario. Cada usuario
# autenticado obtendrá su subcarpeta `<HOST_DATA_DIR>/<username>/processed`.
HOST_DATA_DIR=./data/glaurlex
# Carpeta donde Authelia guarda su sqlite/sesiones/notificaciones.
AUTHELIA_DATA_DIR=./data/authelia/data
# Fichero donde Traefik almacena los certificados ACME (debe existir con
# permisos 600: `touch <ruta> && chmod 600 <ruta>`).
ACME_STORAGE_FILE=./data/traefik/acme.json

# --- Comportamiento de la app --------------------------------------------
APP_ENV=prod
# Cabecera que Traefik inyecta con el usuario autenticado (Remote-User).
GLAURLEX_REMOTE_USER_HEADER=Remote-User
# 1 = exige que la cabecera de auth esté presente (deniega si se salta el proxy).
GLAURLEX_REQUIRE_AUTH=1

# --- Zona horaria ---------------------------------------------------------
TZ=Europe/Madrid
